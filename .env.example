# X/Twitter API (Basic tier - $100/mo)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_BOT_USER_ID=

# BCH Wallet — 24-word BIP39 mnemonic. NEVER commit this.
MASTER_SEED_MNEMONIC=

# Network: "mainnet" or "testnet"
BCH_NETWORK=testnet

# Bot Configuration
POLL_INTERVAL_MS=15000
REQUIRED_CONFIRMATIONS=3
MIN_TIP_SATOSHIS=1000
MIN_WITHDRAWAL_SATOSHIS=10000
MAX_WITHDRAWAL_SATOSHIS=100000000
WITHDRAWAL_FEE_SATOSHIS=500
TIP_FEE_PERCENT=1

# Database
DB_PATH=./data/tipbot.db

# Logging
LOG_LEVEL=info
